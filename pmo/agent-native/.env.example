# ──────────────────────────────────────────────────────────────────────────
# PMO agent-native sidecar — env template.
# Copy to `.env` and fill from `supabase status -o env`. NEVER commit a real key.
# ──────────────────────────────────────────────────────────────────────────

# Supabase project URL (local pilot API origin, NOT the direct DB port).
SUPABASE_URL=http://127.0.0.1:54321

# Supabase keys from `supabase status -o env`.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# agent-native OWN-table DB URL. Uses a DEDICATED ROLE (agent_native_app) whose
# default search_path is `agent_native, public` so the framework's raw DDL lands
# in the isolated `agent_native` schema — never PMO's `public` schema.
# The role + search_path are created once on the local DB (see nitro.config.ts
# comment). The direct DB port for local Supabase is 54322 (NOT 54321).
DATABASE_URL=postgresql://agent_native_app:agent_native_pw@127.0.0.1:54322/postgres

# Optional overrides for the agent_native_app role connection.
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=54322
# POSTGRES_PASSWORD=agent_native_pw

# Nitro dev server port.
PORT=8100
