# agent-native/core@0.84.8 declares an OPTIONAL peer react-router@>=8; PMO uses
# react-router-dom@7. legacy-peer-deps ignores the optional-peer conflict.
# Side effect: npm no longer auto-installs peer deps, so required peers MUST be
# declared explicitly in package.json (e.g. react-is, a required peer of recharts).
legacy-peer-deps=true
