# legacy-peer-deps=true is REQUIRED (re-verified 2026-07-01, I-2): @agent-native/core
# declares an OPTIONAL peer react-router@>=8, but react-router-dom@7 transitively
# pulls react-router@7 into the tree, so modern npm still ERESOLVEs on the clash
# (`peerOptional react-router@">=8" ... Found: react-router@7.18.1`). Removing
# this flag breaks `npm install`. Side effect: npm no longer auto-installs peer
# deps and silently swallows ALL peer mismatches, so REQUIRED peers that PMO
# pins (e.g. react/react-dom/typescript) are guarded by
# `npm run check:peers` (scripts/check-required-peers.mjs) — wired into `verify`
# and CI — which fails on any unsatisfied required peer while tolerating the
# optional react-router clash.
legacy-peer-deps=true
