# op-get.sh COORDINATES for the PROD Supabase DB secret — NOT a secret, safe to commit.
# (The Supabase Cloud project is "prod" in this setup, functionally staging.)
# The real secret is fetched at runtime via `op-get.sh <item> <vault> <field>`, which loads
# the 1Password service-account token itself. Create a 1Password item in vault AS holding a
# SESSION-mode connection URI in a field labelled `db_url`: the DIRECT connection (port 5432) or
# the SESSION POOLER (port 5432, `postgres.<ref>` user). NOT the transaction pooler (6543) —
# transaction mode breaks `db push`/DDL. Dashboard → Settings → Database → Connection string.
OP_PROD_ITEM=pmo-supabase-prod
OP_PROD_VAULT=AS
OP_PROD_FIELD=db_url
