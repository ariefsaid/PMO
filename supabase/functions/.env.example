# Edge-function secrets — LOCAL DEV template.
#
# Copy to `supabase/functions/.env` (gitignored) and fill ANTHROPIC_API_KEY, then run:
#   supabase functions serve agent-chat compose-view --env-file supabase/functions/.env --no-verify-jwt
# See docs/environments.md → "Edge Functions (local dev + prod deploy)".
#
# NEVER commit the filled `.env`. In PROD these are set with `supabase secrets set`, not a file.

# REQUIRED — the LLM key the agent-chat / compose-view deputies call Anthropic with.
# NFR-AR-SEC-001: function secret only; never the client, never committed.
OPENROUTER_API_KEY=

# AUTO-INJECTED by the Supabase runtime for both `functions serve` (local) and deployed
# functions — you do NOT need to set these locally; listed for reference only.
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=<local anon key from `supabase status`>
# SUPABASE_SERVICE_ROLE_KEY=<local service-role key from `supabase status`>
AGENT_MODEL_DEFAULT=deepseek/deepseek-v4-flash
AGENT_MODEL_COMPOSE=
